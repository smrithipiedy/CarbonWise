PORT=5000
NODE_ENV=development

# Google Gemini (set USE_GEMINI=true and provide key to enable AI insights)
USE_GEMINI=false
GEMINI_API_KEY=

# Google Cloud Firestore (optional — defaults to in-memory storage)
USE_FIRESTORE=false
PROJECT_ID=your-gcp-project-id
REGION=us-central1

# Optional comma-separated allowed origins for production CORS
# CORS_ORIGIN=https://your-domain.com
